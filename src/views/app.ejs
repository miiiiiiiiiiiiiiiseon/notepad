<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>나의 메모장</title>
  <link rel="stylesheet" href="/css/style.css" />
  <!-- Quill 리치 텍스트 에디터 (CDN) -->
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />
</head>
<body>
  <div class="app">
    <!-- 좌측 사이드바: 노트북 / 태그 -->
    <aside class="sidebar">
      <div class="brand">📒 메모장</div>

      <button id="newNoteBtn" class="primary-btn">＋ 새 노트</button>

      <nav class="nav">
        <a href="#" class="nav-item active" data-filter="all">📄 모든 노트</a>
      </nav>

      <div class="section-head">
        <span>노트북</span>
        <button id="addNotebookBtn" title="노트북 추가">＋</button>
      </div>
      <ul id="notebookList" class="list"></ul>

      <div class="section-head"><span>태그</span></div>
      <ul id="tagList" class="list"></ul>

      <div class="user-bar">
        <span class="user-email" title="<%= email %>"><%= email %></span>
        <form method="POST" action="/logout">
          <button type="submit" class="logout-btn">로그아웃</button>
        </form>
      </div>
    </aside>

    <!-- 중앙: 노트 목록 -->
    <section class="note-list-pane">
      <div class="search-bar">
        <input id="searchInput" type="search" placeholder="🔍 노트 검색..." />
      </div>
      <div id="listTitle" class="list-title">모든 노트</div>
      <ul id="noteList" class="note-list"></ul>
    </section>

    <!-- 우측: 에디터 -->
    <section class="editor-pane">
      <div id="editorEmpty" class="editor-empty">
        <p>노트를 선택하거나 <b>새 노트</b>를 만들어 보세요.</p>
      </div>

      <div id="editorWrap" class="editor-wrap hidden">
        <div class="editor-top">
          <input id="noteTitle" class="note-title-input" placeholder="제목 없음" />
          <button id="deleteNoteBtn" class="danger-btn" title="삭제">🗑</button>
        </div>

        <div class="editor-meta">
          <label>노트북
            <select id="noteNotebook"></select>
          </label>
          <label class="tags-label">태그
            <input id="noteTags" placeholder="쉼표로 구분 (예: 업무, 아이디어)" />
          </label>
        </div>

        <div id="editor"></div>
        <div class="save-status" id="saveStatus"></div>
      </div>
    </section>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
