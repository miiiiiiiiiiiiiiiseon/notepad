<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>회원가입 · 메모장</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="auth-page">
  <form class="auth-card" method="POST" action="/register">
    <h1>📒 나의 메모장</h1>
    <p class="auth-sub">새 계정 만들기</p>
    <% if (error) { %><div class="auth-error"><%= error %></div><% } %>
    <input type="email" name="email" placeholder="이메일" required autofocus />
    <input type="password" name="password" placeholder="비밀번호 (6자 이상)" required />
    <button type="submit">회원가입</button>
    <p class="auth-switch">이미 계정이 있으신가요? <a href="/login">로그인</a></p>
  </form>
</body>
</html>
