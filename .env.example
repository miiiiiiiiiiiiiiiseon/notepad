# 로컬 개발용 환경변수 예시. 복사해서 .env 로 만드세요.
# Render 배포 시에는 render.yaml 이 DATABASE_URL 과 SESSION_SECRET 을 자동 주입합니다.

# PostgreSQL 연결 문자열
DATABASE_URL=postgresql://user:password@localhost:5432/notepad

# 세션 암호화 키 (아무 랜덤 문자열)
SESSION_SECRET=change-me-to-a-long-random-string

# 포트 (선택)
PORT=3000

# 로컬 PostgreSQL 사용 시 SSL 끄기 (Render 에서는 비워두세요)
PGSSL=false
