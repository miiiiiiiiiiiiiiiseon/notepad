# 로컬 개발용 환경변수 예시. 복사해서 .env 로 만드세요.
# Render 배포 시에는 render.yaml + 대시보드에서 값을 설정합니다.

# Turso (libSQL) 접속 정보 (https://turso.tech 대시보드에서 확인)
TURSO_URL=libsql://your-database.turso.io
TURSO_TOKEN=your-turso-auth-token

# 세션 암호화 키 (아무 랜덤 문자열)
SESSION_SECRET=change-me-to-a-long-random-string

# 포트 (선택)
PORT=3000
